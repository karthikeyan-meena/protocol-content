{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "events", "dining_topics", "address_entries"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "events": {"type": "array", "minItems": 1},
    "dining_topics": {"type": "array", "minItems": 1},
    "address_entries": {"type": "array", "minItems": 1}
  }
}
